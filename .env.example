# Copy to .env (gitignored). NO secrets in code — keys live here only.
# Phase 1 uses the fake "echo" provider and needs none of these.
# Phase 4 wires real providers; uncomment what you enable.

# Cloud AI keys — set the one(s) for the provider(s) you pick in the app's ✨ AI menu.
# ANTHROPIC_API_KEY=   # Claude
# OPENAI_API_KEY=      # ChatGPT (OpenAI)
# GEMINI_API_KEY=      # Gemini
# Local Ollama (native API base + model). Defaults shown — no need to set unless different:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:4b

# Path to the local config file (defaults to ./config.local.json, then ./config.example.json)
# UNIFIED_INBOX_CONFIG=./config.local.json

# Where the SQLite store lives (defaults to ./data/inbox.sqlite, or Electron userData in-app)
# UNIFIED_INBOX_DB=./data/inbox.sqlite
